---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const projects = [
  { title: 'Plataforma Cloud', desc: 'Sistema distribuido con escalabilidad automática.', tech: ['Go', 'Docker'] },
  { title: 'E-commerce Pro', desc: 'Tienda moderna con pagos integrados con Stripe.', tech: ['Next.js', 'PostgreSQL'] },
  { title: 'IA Analytics', desc: 'Dashboard inteligente para análisis de datos.', tech: ['Python', 'TensorFlow'] },
];

const skillCategories = [
  {
    title: 'Frontend',
    icon: 'M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
    skills: ['React', 'Astro', 'Tailwind CSS', 'TypeScript', 'Next.js']
  },
  {
    title: 'Backend',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    skills: ['Node.js', 'PostgreSQL', 'Go', 'Python', 'Docker']
  },
  {
    title: 'Diseño & Herramientas',
    icon: 'M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 011 1V4z',
    skills: ['Figma', 'Git', 'TensorFlow', 'Agile', 'CI/CD']
  }
];

const highlights = [
  { label: 'Años Experiencia', value: '3+' },
  { label: 'Proyectos Listos', value: '15+' },
  { label: 'Países Clientes', value: '5+' },
];
---

<html lang="es" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Portafolio - l1tesg</title>
	</head>
	<body class="relative flex flex-col min-h-screen overflow-x-hidden bg-slate-950 text-slate-100 font-sans selection:bg-indigo-500/30">
		<!-- Capa decorativa del fondo -->
		<div class="fixed inset-0 -z-10 pointer-events-none">
			<div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.15) 1px, transparent 0); background-size: 32px 32px;"></div>
			<div class="absolute inset-0 bg-grid opacity-20"></div>
			<div class="absolute top-[-10%] left-[-10%] h-[500px] w-[500px] rounded-full bg-indigo-500/20 blur-[120px] animate-pulse"></div>
			<div class="absolute bottom-[20%] right-[-10%] h-[600px] w-[600px] rounded-full bg-blue-500/10 blur-[120px]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(2,6,23,0.9)_100%)]"></div>
		</div>

		<Header />
		
		<main class="flex-grow container mx-auto px-4 sm:px-6 lg:px-8 relative">
			<!-- Hero Section -->
			<section class="min-h-[80vh] flex flex-col justify-center items-center text-center space-y-8 py-20 reveal">
				<span class="inline-block px-4 py-1.5 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-400 text-sm font-medium">
					Nueva Era Digital
				</span>
				
				<h2 class="text-6xl font-extrabold tracking-tight text-white sm:text-8xl bg-clip-text text-transparent bg-gradient-to-b from-white to-slate-400 leading-tight pb-2 max-w-5xl">
					Explorando el futuro con código moderno.
				</h2>
				
				<p class="text-xl leading-relaxed text-slate-400 max-w-2xl mx-auto">
					Diseñando interfaces minimalistas con experiencias digitales memorables utilizando Astro con Tailwind CSS.
				</p>
				
				<div class="flex flex-col sm:flex-row justify-center gap-6 pt-8">
					<a href="#contacto" class="px-10 py-4 rounded-xl bg-indigo-600 text-white font-bold shadow-xl shadow-indigo-500/20 hover:bg-indigo-500 hover:scale-105 transition-all duration-300">
						Escríbeme
					</a>
					<a href="#proyectos" class="px-10 py-4 rounded-xl bg-slate-800 text-white border border-slate-700 font-bold hover:bg-slate-700 hover:scale-105 transition-all duration-300">
						Ver Proyectos
					</a>
				</div>
			</section>

			<!-- Sobre mí Section -->
			<section id="sobre-mi" class="py-32 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center reveal">
				<div class="relative group">
					<div class="absolute -inset-4 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-3xl blur-2xl opacity-20 group-hover:opacity-30 transition duration-500"></div>
					<div class="relative aspect-square rounded-3xl overflow-hidden border border-white/10 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-8">
						<div class="text-indigo-400">
							<svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
								<circle cx="12" cy="7" r="4"></circle>
							</svg>
						</div>
					</div>
				</div>
				
				<div class="space-y-8">
					<div class="space-y-4">
						<h3 class="text-4xl font-bold text-white tracking-tight">Sobre mí</h3>
						<p class="text-lg text-slate-400 leading-relaxed">
							Soy un desarrollador apasionado por crear soluciones digitales que combinen rendimiento con diseño impecable. Con enfoque en tecnologías web modernas, busco siempre la mejor experiencia para el usuario final.
						</p>
						<p class="text-lg text-slate-400 leading-relaxed">
							Mi proceso se basa en la comunicación constante con la iteración rápida, asegurando resultados que superen las expectativas.
						</p>
					</div>
					
					<div class="grid grid-cols-3 gap-6">
						{highlights.map((h) => (
							<div class="p-4 rounded-2xl bg-white/5 border border-white/10 text-center space-y-1">
								<div class="text-2xl font-bold text-indigo-400">{h.value}</div>
								<div class="text-xs text-slate-500 uppercase tracking-wider">{h.label}</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Proyectos Section -->
			<section id="proyectos" class="py-32 space-y-16 reveal">
				<div class="text-center space-y-4">
					<h3 class="text-4xl font-bold text-white tracking-tight">Proyectos Destacados</h3>
					<p class="text-slate-400 max-w-xl mx-auto text-lg">Selección de trabajos recientes desarrollados con tecnologías modernas.</p>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{projects.map((p) => (
						<div class="group p-8 rounded-2xl bg-white/5 border border-white/10 hover:border-indigo-500/50 transition-all duration-300 hover:bg-white/[0.08] reveal">
							<h4 class="text-2xl font-bold text-white mb-4 group-hover:text-indigo-400 transition-colors">{p.title}</h4>
							<p class="text-slate-400 mb-6 leading-relaxed">{p.desc}</p>
							<div class="flex flex-wrap gap-2">
								{p.tech.map((t) => (
									<span class="px-3 py-1 text-xs rounded-lg bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">{t}</span>
								))}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Habilidades Section -->
			<section id="habilidades" class="py-32 space-y-16 reveal">
				<div class="text-center space-y-4">
					<h3 class="text-4xl font-bold text-white tracking-tight">Habilidades Técnicas</h3>
					<p class="text-slate-400 max-w-xl mx-auto text-lg">Mi stack tecnológico y herramientas principales.</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{skillCategories.map((cat) => (
						<div class="p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-indigo-500/30 transition-all duration-500 group">
							<div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 mb-6 group-hover:scale-110 transition-transform duration-500">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d={cat.icon}></path>
								</svg>
							</div>
							<h4 class="text-xl font-bold text-white mb-6">{cat.title}</h4>
							<div class="flex flex-wrap gap-2">
								{cat.skills.map((s) => (
									<span class="px-4 py-2 rounded-xl bg-slate-900 border border-slate-800 text-sm font-medium text-slate-400 hover:text-indigo-400 hover:border-indigo-500/50 transition-colors cursor-default">
										{s}
									</span>
								))}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Contacto Section -->
			<section id="contacto" class="py-32 space-y-16 reveal">
				<div class="text-center space-y-4">
					<h3 class="text-4xl font-bold text-white tracking-tight">Escríbeme</h3>
					<p class="text-slate-400 max-w-xl mx-auto text-lg">¿Tienes un proyecto en mente? Hablemos sobre cómo podemos hacerlo realidad.</p>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto items-start">
					<!-- Info de contacto -->
					<div class="space-y-8 reveal">
						<div class="p-8 rounded-2xl bg-white/5 border border-white/10 space-y-6">
							<h4 class="text-2xl font-bold text-white">Información Directa</h4>
							<div class="space-y-4">
								<div class="flex items-center gap-4 text-slate-400">
									<div class="p-3 rounded-lg bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">📧</div>
									<span>hola@l1tesg.dev</span>
								</div>
								<div class="flex items-center gap-4 text-slate-400">
									<div class="p-3 rounded-lg bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">📍</div>
									<span>Remoto / Global</span>
								</div>
							</div>
						</div>
						
						<div class="flex gap-4">
							<a href="#" class="flex-1 p-4 rounded-xl bg-slate-900 border border-slate-800 text-center font-bold text-slate-300 hover:text-indigo-400 hover:border-indigo-500/50 transition-all">Github</a>
							<a href="#" class="flex-1 p-4 rounded-xl bg-slate-900 border border-slate-800 text-center font-bold text-slate-300 hover:text-indigo-400 hover:border-indigo-500/50 transition-all">Linkedin</a>
						</div>
					</div>

					<!-- Formulario -->
					<form class="space-y-6 reveal p-8 rounded-2xl bg-white/5 border border-white/10">
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label class="text-sm font-medium text-slate-400 ml-1">Nombre</label>
								<input type="text" placeholder="Tu nombre" class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/50 outline-none transition-all" />
							</div>
							<div class="space-y-2">
								<label class="text-sm font-medium text-slate-400 ml-1">Correo</label>
								<input type="email" placeholder="tu@email.com" class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/50 outline-none transition-all" />
							</div>
						</div>
						<div class="space-y-2">
							<label class="text-sm font-medium text-slate-400 ml-1">Mensaje</label>
							<textarea rows="4" placeholder="¿En qué puedo ayudarte?" class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/50 outline-none transition-all resize-none"></textarea>
						</div>
						<button type="submit" class="w-full py-4 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-500 shadow-lg shadow-indigo-500/20 transition-all active:scale-95">
							Enviar Mensaje
						</button>
					</form>
				</div>
			</section>
		</main>

		<Footer />

		<script is:inline>
			const revealElements = () => {
				const observerOptions = {
					threshold: 0.1,
					rootMargin: '0px 0px -50px 0px'
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
						} else {
							entry.target.classList.remove('active');
						}
					});
				}, observerOptions);

				document.querySelectorAll('.reveal').forEach((el) => {
					observer.observe(el);
				});
			};

			revealElements();
			document.addEventListener('astro:after-swap', revealElements);
		</script>
	</body>
</html>
